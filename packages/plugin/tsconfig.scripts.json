{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "sourceMap": false,
    "outDir": "dist-scripts"
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "scripts/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
        "src/**/*.test.ts",
        "src/**/__tests__/**",
        "scripts/experiments",
        "scripts/lib",
        "scripts/smoke-node-sqlite.ts",
        "scripts/test-historian-prompt.ts"
    ]}
